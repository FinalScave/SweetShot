{
  "name": "systemverilog",
  "fileSuffixes": [".sv", ".svh"],
  "variables": {
    "identifier": "[a-zA-Z_][a-zA-Z0-9_$]*",
    "escapedIdentifier": "\\\\[^\\s]+",
    "whiteSpace": "[ \\t\\f]",
    "any": "[\\S\\s]",
    "builtinType": "bit|logic|byte|shortint|int|integer|longint|time|real|shortreal|string|event|chandle|void|reg|wire|tri|tri0|tri1|wand|wor|supply0|supply1"
  },
  "fragments": {
    "urlRule": [
      {
        "pattern": "(?:(?:https?|ftp)://|www\\.)[A-Za-z0-9._~:/?#\\[\\]@!$&()*+,;=%-]*[A-Za-z0-9_~/#@%=+-]",
        "style": "url"
      }
    ],
    "lineCommentRule": [
      {
        "pattern": "(//)(.*)",
        "styles": [1, "comment", 2, "comment"],
        "subStates": [2, "lineCommentContent"]
      }
    ],
    "doubleQuotedStringRule": [
      {
        "pattern": "(\")((?:[^\"\\\\]|\\\\.)*)(\")",
        "styles": [1, "string", 3, "string"],
        "subStates": [2, "stringContent"]
      }
    ],
    "macroRefRule": [
      {
        "pattern": "(`)([A-Za-z_][A-Za-z0-9_$]*)",
        "styles": [1, "punctuation", 2, "macro"]
      }
    ],
    "systemTaskRule": [
      {
        "pattern": "(\\$)([A-Za-z_][A-Za-z0-9_$]*)",
        "styles": [1, "punctuation", 2, "builtin"]
      }
    ],
    "escapedIdentifierRule": [
      {
        "pattern": "${escapedIdentifier}",
        "style": "variable"
      }
    ],
    "basedNumberRule": [
      {
        "pattern": "\\b(?:\\d+)?'(?:s)?[bB][01_xzXZ?]+\\b",
        "style": "number"
      },
      {
        "pattern": "\\b(?:\\d+)?'(?:s)?[oO][0-7_xzXZ?]+\\b",
        "style": "number"
      },
      {
        "pattern": "\\b(?:\\d+)?'(?:s)?[dD][-+]?[0-9_]+\\b",
        "style": "number"
      },
      {
        "pattern": "\\b(?:\\d+)?'(?:s)?[hH][0-9a-fA-F_xzXZ?]+\\b",
        "style": "number"
      },
      {
        "pattern": "\\b'[01xXzZ]\\b",
        "style": "number"
      }
    ],
    "integerNumberRule": [
      {
        "pattern": "\\b[0-9][0-9_]*(?:\\.[0-9_]+)?(?:[eE][+-]?[0-9_]+)?\\b",
        "style": "number"
      }
    ],
    "attributeRule": [
      {
        "pattern": "(\\(\\*)(.*?)(\\*\\))",
        "styles": [1, "annotation", 3, "annotation"],
        "subStates": [2, "attributeContent"]
      }
    ]
  },
  "states": {
    "default": [
      {
        "pattern": "(?m)^\\s*(`)(ifdef|ifndef|elsif|else|endif|define|undef|include|timescale|default_nettype|celldefine|endcelldefine|resetall|pragma|begin_keywords|end_keywords)\\b",
        "styles": [1, "punctuation", 2, "preprocessor"]
      },
      {
        "pattern": "(?m)^\\s*(`define)\\b\\s*(${identifier})",
        "styles": [1, "preprocessor", 2, "macro"]
      },
      {
        "include": "attributeRule"
      },
      {
        "pattern": "/\\*",
        "style": "comment",
        "state": "blockComment"
      },
      {
        "include": "lineCommentRule"
      },
      {
        "pattern": "\\b(module|interface|program)\\b\\s+(${identifier})\\s*(#)\\s*(\\()",
        "styles": [1, "keyword", 2, "class", 3, "punctuation", 4, "punctuation"],
        "state": "parenList"
      },
      {
        "pattern": "\\b(module|interface|program)\\b\\s+(${identifier})\\s*(\\()",
        "styles": [1, "keyword", 2, "class", 3, "punctuation"],
        "state": "parenList"
      },
      {
        "pattern": "\\b(module|interface|program)\\b\\s+(${identifier})",
        "styles": [1, "keyword", 2, "class"]
      },
      {
        "pattern": "\\b(package)\\b\\s+(${identifier})",
        "styles": [1, "keyword", 2, "class"]
      },
      {
        "pattern": "\\b(class)\\b\\s+(${identifier})",
        "styles": [1, "keyword", 2, "class"]
      },
      {
        "pattern": "\\b(import|export)\\b\\s+(${identifier}(?:::${identifier})*)(::)(\\*)",
        "styles": [1, "keyword", 2, "class", 3, "punctuation", 4, "punctuation"]
      },
      {
        "pattern": "\\b(import|export)\\b\\s+(${identifier}(?:::${identifier})*)",
        "styles": [1, "keyword", 2, "class"]
      },
      {
        "pattern": "\\b(typedef)\\b\\s+(enum|struct|union)\\b",
        "styles": [1, "keyword", 2, "keyword"]
      },
      {
        "pattern": "\\b(function|task)\\b(?:[^\\n();]*?)\\b(${identifier})(?=${whiteSpace}*\\()",
        "styles": [1, "keyword", 2, "method"]
      },
      {
        "pattern": "\\b(function|task)\\b\\s+(automatic|static|virtual|pure|extern|const)?\\b",
        "styles": [1, "keyword", 2, "keyword"]
      },
      {
        "pattern": "\\b(?:always_comb|always_ff|always_latch|always|initial|final|generate|endgenerate|begin|end|if|else|case|endcase|for|foreach|while|repeat|forever|fork|join|join_any|join_none|assert|assume|cover|covergroup|endgroup|coverpoint|cross|bins|binsof|iff|inside|dist|property|sequence|endproperty|endsequence|disable|return|wait|unique|priority|unique0|new|this|super|null|enum|struct|union|timeunit|timeprecision)\\b",
        "style": "keyword"
      },
      {
        "pattern": "\\b(?:input|output|inout|ref|var|parameter|localparam|typedef|modport|clocking|alias|assign|force|release|signed|unsigned|packed|const|rand|randc|wire|logic|bit|byte|shortint|int|integer|longint|time|real|shortreal|string|event|chandle|void)\\b",
        "style": "keyword"
      },
      {
        "pattern": "\\b(${identifier})(::)(${identifier})",
        "styles": [1, "class", 2, "punctuation", 3, "class"]
      },
      {
        "pattern": "${identifier}",
        "style": "variable"
      },
      {
        "pattern": "(${identifier})${whiteSpace}*(\\()",
        "styles": [1, "method", 2, "punctuation"]
      },
      {
        "include": "macroRefRule"
      },
      {
        "include": "systemTaskRule"
      },
      {
        "include": "escapedIdentifierRule"
      },
      {
        "include": "basedNumberRule"
      },
      {
        "include": "integerNumberRule"
      },
      {
        "pattern": "\"",
        "style": "string",
        "state": "string"
      },
      {
        "pattern": "[=+\\-*/%&|^~!<>?:.,;()\\[\\]{}@]",
        "style": "punctuation"
      }
    ],
    "parenList": [
      {
        "pattern": "\\)",
        "style": "punctuation",
        "state": "headerTail"
      },
      {
        "include": "attributeRule"
      },
      {
        "pattern": "/\\*",
        "style": "comment",
        "state": "blockComment"
      },
      {
        "include": "lineCommentRule"
      },
      {
        "pattern": "\"",
        "style": "string",
        "state": "string"
      },
      {
        "include": "macroRefRule"
      },
      {
        "include": "systemTaskRule"
      },
      {
        "include": "escapedIdentifierRule"
      },
      {
        "include": "basedNumberRule"
      },
      {
        "include": "integerNumberRule"
      },
      {
        "pattern": "\\b(?:parameter|localparam|input|output|inout|ref|var|type|signed|unsigned|packed|const)\\b",
        "style": "keyword"
      },
      {
        "pattern": "\\b${builtinType}\\b",
        "style": "builtin"
      },
      {
        "pattern": "\\b(${identifier})(::)(${identifier})",
        "styles": [1, "class", 2, "punctuation", 3, "class"]
      },
      {
        "pattern": "${identifier}",
        "style": "variable"
      },
      {
        "pattern": "(${identifier})${whiteSpace}*(\\()",
        "styles": [1, "method", 2, "punctuation"]
      },
      {
        "pattern": "[=+\\-*/%&|^~!<>?:.,;\\[\\]{}@]",
        "style": "punctuation"
      },
      {
        "pattern": "${identifier}",
        "style": "variable"
      },
      {
        "onLineEndState": "parenList"
      }
    ],
    "headerTail": [
      {
        "pattern": "\\(",
        "style": "punctuation",
        "state": "parenList"
      },
      {
        "pattern": ";",
        "style": "punctuation",
        "state": "default"
      },
      {
        "include": "attributeRule"
      },
      {
        "pattern": "/\\*",
        "style": "comment",
        "state": "blockComment"
      },
      {
        "include": "lineCommentRule"
      },
      {
        "include": "macroRefRule"
      },
      {
        "include": "systemTaskRule"
      },
      {
        "include": "escapedIdentifierRule"
      },
      {
        "include": "basedNumberRule"
      },
      {
        "include": "integerNumberRule"
      },
      {
        "pattern": "\"",
        "style": "string",
        "state": "string"
      },
      {
        "pattern": "[=+\\-*/%&|^~!<>?:.,\\[\\]{}@]",
        "style": "punctuation"
      },
      {
        "pattern": "${identifier}",
        "style": "variable"
      },
      {
        "onLineEndState": "headerTail"
      }
    ],
    "string": [
      {
        "pattern": "\"",
        "style": "string",
        "state": "default"
      },
      {
        "include": "urlRule"
      },
      {
        "pattern": "\\\\.",
        "style": "string"
      },
      {
        "pattern": "${any}",
        "style": "string"
      }
    ],
    "attributeContent": [
      {
        "pattern": "\\*\\)",
        "style": "annotation",
        "state": "default"
      },
      {
        "include": "urlRule"
      },
      {
        "include": "macroRefRule"
      },
      {
        "include": "systemTaskRule"
      },
      {
        "include": "escapedIdentifierRule"
      },
      {
        "include": "basedNumberRule"
      },
      {
        "include": "integerNumberRule"
      },
      {
        "include": "lineCommentRule"
      },
      {
        "pattern": "\"",
        "style": "string",
        "state": "string"
      },
      {
        "pattern": "${any}",
        "style": "annotation"
      }
    ],
    "blockComment": [
      {
        "pattern": "\\*/",
        "style": "comment",
        "state": "default"
      },
      {
        "include": "urlRule"
      },
      {
        "pattern": "${any}",
        "style": "comment"
      }
    ],
    "lineCommentContent": [
      {
        "include": "urlRule"
      },
      {
        "pattern": "${any}",
        "style": "comment"
      }
    ]
  },
  "scopeRules": {
    "skips": [
      { "kind": "lineComment", "start": "//" },
      { "kind": "blockComment", "start": "/*", "end": "*/" },
      { "kind": "string", "start": "\"", "end": "\"", "escape": "\\" }
    ],
    "rules": [
      { "kind": "word", "start": "module", "end": "endmodule" },
      { "kind": "word", "start": "interface", "end": "endinterface" },
      { "kind": "word", "start": "package", "end": "endpackage" },
      { "kind": "word", "start": "class", "end": "endclass" },
      { "kind": "word", "start": "function", "end": "endfunction" },
      { "kind": "word", "start": "task", "end": "endtask" },
      { "kind": "word", "start": "begin", "end": "end" },
      { "kind": "word", "start": "case", "end": "endcase" },
      { "kind": "word", "start": "generate", "end": "endgenerate" }
    ]
  }
}
