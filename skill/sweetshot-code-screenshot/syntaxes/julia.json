{
  "name": "julia",
  "fileSuffixes": [".jl"],
  "variables": {
    "identifier": "[A-Za-z_][A-Za-z0-9_!]*",
    "qualifiedIdentifier": "${identifier}(?:\\.${identifier})*",
    "whiteSpace": "[ \\t\\f]",
    "any": "[\\S\\s]"
  },
  "fragments": {
    "urlRule": [
      {
        "pattern": "(?:(?:https?|ftp)://|www\\.)[A-Za-z0-9._~:/?#\\[\\]@!$&()*+,;=%-]*[A-Za-z0-9_~/#@%=+-]",
        "style": "url"
      }
    ],
    "lineCommentRule": [
      {
        "pattern": "(#)(.*)",
        "styles": [1, "comment", 2, "comment"],
        "subStates": [2, "lineCommentContent"]
      }
    ],
    "blockCommentStartRule": [
      {
        "pattern": "#=",
        "style": "comment",
        "state": "blockComment"
      }
    ],
    "stringInterpolationExprRule": [
      {
        "pattern": "(\\$\\()([^)]*)(\\))",
        "styles": [1, "punctuation", 3, "punctuation"],
        "subStates": [2, "default"]
      }
    ],
    "stringInterpolationVarRule": [
      {
        "pattern": "(\\$)(${identifier})",
        "styles": [1, "punctuation", 2, "variable"]
      }
    ],
    "stringEscapeRule": [
      {
        "pattern": "\\\\.",
        "style": "string"
      }
    ],
    "stringAnyCharRule": [
      {
        "pattern": "${any}",
        "style": "string"
      }
    ]
  },
  "states": {
    "default": [
      {
        "pattern": "\\b(module)\\b${whiteSpace}+(${qualifiedIdentifier})",
        "styles": [1, "keyword", 2, "class"]
      },
      {
        "pattern": "\\b(mutable)${whiteSpace}+(struct)\\b${whiteSpace}+(${identifier})(\\{)([^{}]*)(\\})",
        "styles": [1, "keyword", 2, "keyword", 3, "class", 4, "punctuation", 6, "punctuation"],
        "subStates": [5, "genericType"]
      },
      {
        "pattern": "\\b(mutable)${whiteSpace}+(struct)\\b${whiteSpace}+(${identifier})",
        "styles": [1, "keyword", 2, "keyword", 3, "class"]
      },
      {
        "pattern": "\\b(abstract)${whiteSpace}+(type)\\b${whiteSpace}+(${identifier})(\\{)([^{}]*)(\\})",
        "styles": [1, "keyword", 2, "keyword", 3, "class", 4, "punctuation", 6, "punctuation"],
        "subStates": [5, "genericType"]
      },
      {
        "pattern": "\\b(abstract)${whiteSpace}+(type)\\b${whiteSpace}+(${identifier})",
        "styles": [1, "keyword", 2, "keyword", 3, "class"]
      },
      {
        "pattern": "\\b(primitive)${whiteSpace}+(type)\\b${whiteSpace}+(${identifier})",
        "styles": [1, "keyword", 2, "keyword", 3, "class"]
      },
      {
        "pattern": "\\b(struct)\\b${whiteSpace}+(${identifier})(\\{)([^{}]*)(\\})",
        "styles": [1, "keyword", 2, "class", 3, "punctuation", 5, "punctuation"],
        "subStates": [4, "genericType"]
      },
      {
        "pattern": "\\b(struct)\\b${whiteSpace}+(${identifier})",
        "styles": [1, "keyword", 2, "class"]
      },
      {
        "pattern": "\\b(function)\\b${whiteSpace}+(${identifier})${whiteSpace}*(\\()",
        "styles": [1, "keyword", 2, "method", 3, "punctuation"],
        "state": "funcParams"
      },
      {
        "pattern": "\\b(macro)\\b${whiteSpace}+(${identifier})${whiteSpace}*(\\()",
        "styles": [1, "keyword", 2, "macro", 3, "punctuation"],
        "state": "funcParams"
      },
      {
        "pattern": "\\b(local|global|const)\\b${whiteSpace}+(${identifier})${whiteSpace}*(=)",
        "styles": [1, "keyword", 2, "variable", 3, "punctuation"]
      },
      {
        "pattern": "\\b(local|global|const)\\b${whiteSpace}+(${identifier})",
        "styles": [1, "keyword", 2, "variable"]
      },
      {
        "pattern": "\\b(let)\\b${whiteSpace}+(${identifier})${whiteSpace}*(=)",
        "styles": [1, "keyword", 2, "variable", 3, "punctuation"]
      },
      {
        "pattern": "\\b(where)\\b${whiteSpace}*(\\{)(${identifier})([^{}]*)(\\})",
        "styles": [1, "keyword", 2, "punctuation", 3, "class", 5, "punctuation"],
        "subStates": [4, "genericType"]
      },
      {
        "pattern": "\\b(?:const|global|local|import|using|export)\\b",
        "style": "keyword"
      },
      {
        "pattern": "\\b(?:begin|if|elseif|else|for|while|try|catch|finally|do|let|quote|return|break|continue|end|where|in)\\b",
        "style": "keyword"
      },
      {
        "pattern": "\\b(?:true|false|nothing|missing)\\b",
        "style": "builtin"
      },
      {
        "pattern": "\\b(?:Int|Int8|Int16|Int32|Int64|UInt|UInt8|UInt16|UInt32|UInt64|Float16|Float32|Float64|Bool|String|Char|Any|Array|Vector|Matrix|Tuple|NamedTuple|Dict|Set|Pair|Complex|Rational|Real|AbstractString|AbstractArray|Module|Function|IO|Regex|AbstractVector|AbstractMatrix)\\b",
        "style": "class"
      },
      {
        "pattern": "(@)(${identifier})",
        "styles": [1, "punctuation", 2, "macro"]
      },
      {
        "pattern": "(:)(${identifier})",
        "styles": [1, "punctuation", 2, "annotation"]
      },
      {
        "pattern": "(${identifier})(::)(${identifier})(\\{)([^{}]*)(\\})",
        "styles": [1, "variable", 2, "punctuation", 3, "class", 4, "punctuation", 6, "punctuation"],
        "subStates": [5, "genericType"]
      },
      {
        "pattern": "(${identifier})(::)(${identifier})",
        "styles": [1, "variable", 2, "punctuation", 3, "class"]
      },
      {
        "pattern": "(${identifier})${whiteSpace}*(\\()",
        "styles": [1, "method", 2, "punctuation"]
      },
      {
        "pattern": "(${identifier})(\\.)(${identifier})${whiteSpace}*(\\()",
        "styles": [1, "variable", 2, "punctuation", 3, "method", 4, "punctuation"]
      },
      {
        "pattern": "(${identifier})(\\.)(${identifier})",
        "styles": [1, "variable", 2, "punctuation", 3, "variable"]
      },
      {
        "pattern": "(${identifier})(\\{)([^{}]*)(\\})",
        "styles": [1, "class", 2, "punctuation", 4, "punctuation"],
        "subStates": [3, "genericType"]
      },
      {
        "pattern": "\\b(raw|r|b)(\\\")",
        "styles": [1, "macro", 2, "string"],
        "state": "specialString"
      },
      {
        "pattern": "\\b(raw|r|b)(\\\"\\\"\\\")",
        "styles": [1, "macro", 2, "string"],
        "state": "specialTripleString"
      },
      {
        "pattern": "\\\"\\\"\\\"",
        "style": "string",
        "state": "tripleString"
      },
      {
        "pattern": "\\\"",
        "style": "string",
        "state": "doubleString"
      },
      {
        "pattern": "`",
        "style": "string",
        "state": "commandString"
      },
      {
        "pattern": "\\b0[xX][0-9A-Fa-f_]+(?:p[+-]?[0-9_]+)?\\b",
        "style": "number"
      },
      {
        "pattern": "\\b0[bB][01_]+\\b",
        "style": "number"
      },
      {
        "pattern": "\\b0[oO][0-7_]+\\b",
        "style": "number"
      },
      {
        "pattern": "\\b(?:[0-9][0-9_]*\\.?[0-9_]*(?:[eE][+-]?[0-9_]+)?(?:im|f16|f32|f64)?)\\b",
        "style": "number"
      },
      {
        "include": "blockCommentStartRule"
      },
      {
        "include": "lineCommentRule"
      },
      {
        "pattern": "::|<:|>:|->|=>|\\+\\+|--|\\.\\.\\.|\\+\\=|\\-\\=|\\*\\=|\\/\\=|==|!=|<=|>=|&&|\\|\\||[.()\\[\\]?!%^&|+\\-*/<>=,{};:]",
        "style": "punctuation"
      }
    ],
    "genericType": [
      {
        "pattern": "\\bwhere\\b|<:",
        "style": "keyword"
      },
      {
        "pattern": "(${identifier})(\\{)([^{}]*)(\\})",
        "styles": [1, "class", 2, "punctuation", 4, "punctuation"],
        "subStates": [3, "genericType"]
      },
      {
        "pattern": "${identifier}",
        "style": "class"
      },
      {
        "pattern": "[,\\[\\]&?:.]",
        "style": "punctuation"
      }
    ],
    "funcParams": [
      {
        "pattern": "\\)",
        "style": "punctuation",
        "state": "default"
      },
      {
        "pattern": "(${identifier})${whiteSpace}*(::)(${identifier})(\\{)([^{}]*)(\\})${whiteSpace}*(=)",
        "styles": [1, "variable", 2, "punctuation", 3, "class", 4, "punctuation", 6, "punctuation", 7, "punctuation"],
        "subStates": [5, "genericType"]
      },
      {
        "pattern": "(${identifier})${whiteSpace}*(::)(${identifier})${whiteSpace}*(=)",
        "styles": [1, "variable", 2, "punctuation", 3, "class", 4, "punctuation"]
      },
      {
        "pattern": "(${identifier})${whiteSpace}*(::)(${identifier})(\\{)([^{}]*)(\\})",
        "styles": [1, "variable", 2, "punctuation", 3, "class", 4, "punctuation", 6, "punctuation"],
        "subStates": [5, "genericType"]
      },
      {
        "pattern": "(${identifier})${whiteSpace}*(::)(${identifier})",
        "styles": [1, "variable", 2, "punctuation", 3, "class"]
      },
      {
        "pattern": "(${identifier})${whiteSpace}*(=)",
        "styles": [1, "variable", 2, "punctuation"]
      },
      {
        "pattern": "${identifier}",
        "style": "variable"
      },
      {
        "pattern": "\\b(raw|r|b)(\\\")",
        "styles": [1, "macro", 2, "string"],
        "state": "specialString"
      },
      {
        "pattern": "\\b(raw|r|b)(\\\"\\\"\\\")",
        "styles": [1, "macro", 2, "string"],
        "state": "specialTripleString"
      },
      {
        "pattern": "\\\"\\\"\\\"",
        "style": "string",
        "state": "tripleString"
      },
      {
        "pattern": "\\\"",
        "style": "string",
        "state": "doubleString"
      },
      {
        "pattern": "`",
        "style": "string",
        "state": "commandString"
      },
      {
        "pattern": "\\.\\.\\.",
        "style": "punctuation"
      },
      {
        "pattern": "\\b(?:true|false|nothing|missing)\\b",
        "style": "builtin"
      },
      {
        "pattern": "\\b(?:[0-9][0-9_]*\\.?[0-9_]*(?:[eE][+-]?[0-9_]+)?(?:im|f16|f32|f64)?)\\b",
        "style": "number"
      },
      {
        "include": "lineCommentRule"
      },
      {
        "includes": ["stringInterpolationExprRule", "stringInterpolationVarRule"]
      },
      {
        "pattern": "[,;:]",
        "style": "punctuation"
      },
      {
        "onLineEndState": "funcParams"
      }
    ],
    "doubleString": [
      {
        "pattern": "\"",
        "style": "string",
        "state": "default"
      },
      {
        "include": "urlRule"
      },
      {
        "includes": ["stringInterpolationExprRule", "stringInterpolationVarRule"]
      },
      {
        "include": "stringEscapeRule"
      },
      {
        "include": "stringAnyCharRule"
      }
    ],
    "tripleString": [
      {
        "pattern": "\\\"\\\"\\\"",
        "style": "string",
        "state": "default"
      },
      {
        "include": "urlRule"
      },
      {
        "includes": ["stringInterpolationExprRule", "stringInterpolationVarRule"]
      },
      {
        "include": "stringEscapeRule"
      },
      {
        "include": "stringAnyCharRule"
      }
    ],
    "specialString": [
      {
        "pattern": "\"",
        "style": "string",
        "state": "default"
      },
      {
        "include": "urlRule"
      },
      {
        "include": "stringEscapeRule"
      },
      {
        "include": "stringAnyCharRule"
      }
    ],
    "specialTripleString": [
      {
        "pattern": "\\\"\\\"\\\"",
        "style": "string",
        "state": "default"
      },
      {
        "include": "urlRule"
      },
      {
        "include": "stringEscapeRule"
      },
      {
        "include": "stringAnyCharRule"
      }
    ],
    "commandString": [
      {
        "pattern": "`",
        "style": "string",
        "state": "default"
      },
      {
        "include": "urlRule"
      },
      {
        "includes": ["stringInterpolationExprRule", "stringInterpolationVarRule"]
      },
      {
        "include": "stringEscapeRule"
      },
      {
        "include": "stringAnyCharRule"
      }
    ],
    "blockComment": [
      {
        "pattern": "=#",
        "style": "comment",
        "state": "default"
      },
      {
        "include": "urlRule"
      },
      {
        "pattern": "${any}",
        "style": "comment"
      },
      {
        "onLineEndState": "blockComment"
      }
    ],
    "lineCommentContent": [
      {
        "include": "urlRule"
      },
      {
        "pattern": "${any}",
        "style": "comment"
      }
    ]
  }
}
