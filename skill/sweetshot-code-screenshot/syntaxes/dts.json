{
  "name": "dts",
  "fileSuffixes": [".dts", ".dtsi"],
  "variables": {
    "identifier": "[a-zA-Z_][a-zA-Z0-9_\\-]*",
    "propertyIdentifier": "#?[a-zA-Z_][a-zA-Z0-9_\\-]*",
    "whiteSpace": "[ \\t\\f]",
    "any": "[\\S\\s]"
  },
  "fragments": {
    "lineCommentRule": [
      {
        "pattern": "(//)(.*)",
        "styles": [1, "comment", 2, "comment"],
        "subStates": [2, "lineCommentContent"]
      }
    ],
    "doubleQuotedStringRule": [
      {
        "pattern": "(\")((?:[^\"\\\\]|\\\\.)*)(\")",
        "styles": [1, "string", 3, "string"],
        "subStates": [2, "stringContent"]
      }
    ]
  },
  "states": {
    "default": [
      {
        "pattern": "/\\*",
        "style": "comment",
        "state": "longComment"
      },
      {
        "pattern": "(?m)^(\\s*)(#)(\\s*)(include|define|undef|if|ifdef|ifndef|elif|else|endif)\\b",
        "styles": [1, "punctuation", 2, "preprocessor", 3, "punctuation", 4, "preprocessor"],
        "state": "preprocessor"
      },
      {
        "pattern": "(/dts-v1/)",
        "styles": [1, "keyword"]
      },
      {
        "pattern": "(/plugin/)",
        "styles": [1, "keyword"]
      },
      {
        "pattern": "(/memreserve/)",
        "styles": [1, "keyword"],
        "state": "memreserve"
      },
      {
        "pattern": "(/delete-node/)",
        "styles": [1, "keyword"],
        "state": "deleteNode"
      },
      {
        "pattern": "(/delete-property/)",
        "styles": [1, "keyword"],
        "state": "deleteProperty"
      },
      {
        "pattern": "(${identifier})(\\s*)(:)",
        "styles": [1, "method", 2, "punctuation", 3, "punctuation"]
      },
      {
        "pattern": "(${identifier})(@)([0-9a-fA-F]+)",
        "styles": [1, "class", 2, "punctuation", 3, "number"]
      },
      {
        "pattern": "(${propertyIdentifier})(\\s*)(=)",
        "styles": [1, "property", 2, "punctuation", 3, "punctuation"],
        "state": "propertyValue"
      },
      {
        "pattern": "(${propertyIdentifier})(\\s*)(;)",
        "styles": [1, "property", 2, "punctuation", 3, "punctuation"]
      },
      {
        "pattern": "(${identifier})",
        "styles": [1, "class"]
      },
      {
        "pattern": "(&)(${identifier})",
        "styles": [1, "punctuation", 2, "variable"]
      },
      {
        "pattern": "(&)(\\{)([^}]+)(\\})",
        "styles": [1, "punctuation", 2, "punctuation", 3, "variable", 4, "punctuation"]
      },
      {
        "pattern": "\\b0x[0-9a-fA-F]+\\b",
        "style": "number"
      },
      {
        "pattern": "\\b[0-9]+\\b",
        "style": "number"
      },
      {
        "include": "doubleQuotedStringRule"
      },
      {
        "pattern": "[{}\\[\\]();,]",
        "style": "punctuation"
      },
      {
        "include": "lineCommentRule"
      }
    ],
    "preprocessor": [
      {
        "pattern": "(<)([^>]+)(>)",
        "styles": [1, "string", 2, "string", 3, "string"]
      },
      {
        "include": "doubleQuotedStringRule"
      },
      {
        "pattern": "\\b[A-Z_][A-Z0-9_]*\\b",
        "style": "variable"
      },
      {
        "onLineEndState": "default"
      }
    ],
    "memreserve": [
      {
        "pattern": "\\b0x[0-9a-fA-F]+\\b",
        "style": "number"
      },
      {
        "pattern": "\\b[0-9]+\\b",
        "style": "number"
      },
      {
        "pattern": ";",
        "style": "punctuation",
        "state": "default"
      },
      {
        "onLineEndState": "default"
      }
    ],
    "deleteNode": [
      {
        "pattern": "(${identifier})",
        "styles": [1, "class"],
        "state": "default"
      },
      {
        "pattern": "(&)(${identifier})",
        "styles": [1, "punctuation", 2, "variable"],
        "state": "default"
      },
      {
        "onLineEndState": "default"
      }
    ],
    "deleteProperty": [
      {
        "pattern": "(${propertyIdentifier})(\\s*)(;)",
        "styles": [1, "property", 2, "punctuation", 3, "punctuation"],
        "state": "default"
      },
      {
        "onLineEndState": "default"
      }
    ],
    "propertyValue": [
      {
        "pattern": "(<)",
        "styles": [1, "punctuation"],
        "state": "cellArray"
      },
      {
        "pattern": "(\\[)",
        "styles": [1, "punctuation"],
        "state": "byteArray"
      },
      {
        "pattern": "(&)(${identifier})",
        "styles": [1, "punctuation", 2, "variable"]
      },
      {
        "pattern": "(&)(\\{)([^}]+)(\\})",
        "styles": [1, "punctuation", 2, "punctuation", 3, "variable", 4, "punctuation"]
      },
      {
        "pattern": "\\b0x[0-9a-fA-F]+\\b",
        "style": "number"
      },
      {
        "pattern": "\\b[0-9]+\\b",
        "style": "number"
      },
      {
        "include": "doubleQuotedStringRule"
      },
      {
        "pattern": ";",
        "style": "punctuation",
        "state": "default"
      },
      {
        "onLineEndState": "default"
      }
    ],
    "cellArray": [
      {
        "pattern": "(>)",
        "styles": [1, "punctuation"],
        "state": "propertyValue"
      },
      {
        "pattern": "(&)(${identifier})",
        "styles": [1, "punctuation", 2, "variable"]
      },
      {
        "pattern": "\\b0x[0-9a-fA-F]+\\b",
        "style": "number"
      },
      {
        "pattern": "\\b[0-9]+\\b",
        "style": "number"
      }
    ],
    "byteArray": [
      {
        "pattern": "(\\])",
        "styles": [1, "punctuation"],
        "state": "propertyValue"
      },
      {
        "pattern": "\\b[0-9a-fA-F]{2}\\b",
        "style": "number"
      }
    ],
    "longComment": [
      {
        "pattern": "\\*/",
        "style": "comment",
        "state": "default"
      },
      {
        "pattern": "${any}",
        "style": "comment"
      }
    ],
    "stringContent": [
      {
        "pattern": "\\\\.",
        "style": "string"
      },
      {
        "pattern": "${any}",
        "style": "string"
      }
    ],
    "lineCommentContent": [
      {
        "pattern": "${any}",
        "style": "comment"
      }
    ]
  }
}
