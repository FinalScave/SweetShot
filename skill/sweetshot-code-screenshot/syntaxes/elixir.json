{
  "name": "elixir",
  "fileSuffixes": [".ex", ".exs"],
  "fileNames": ["mix.exs"],
  "variables": {
    "identifier": "[a-z_][A-Za-z0-9_]*[!?]?",
    "moduleIdentifier": "[A-Z][A-Za-z0-9_]*(?:\\.[A-Z][A-Za-z0-9_]*)*",
    "atomIdentifier": "(?:[A-Za-z_][A-Za-z0-9_@!?/]*|[A-Z][A-Za-z0-9_@!?/]*|[+\\-*/<>=!?|&^~]+)",
    "whiteSpace": "[ \\t\\f]",
    "any": "[\\S\\s]"
  },
  "fragments": {
    "urlRule": [
      {
        "pattern": "(?:(?:https?|ftp)://|www\\.)[A-Za-z0-9._~:/?#\\[\\]@!$&()*+,;=%-]*[A-Za-z0-9_~/#@%=+-]",
        "style": "url"
      }
    ],
    "lineCommentRule": [
      {
        "pattern": "(#)(.*)",
        "styles": [1, "comment", 2, "comment"],
        "subStates": [2, "lineCommentContent"]
      }
    ],
    "doubleQuotedStringRule": [
      {
        "pattern": "(\")((?:[^\"\\\\]|\\\\.)*)(\")",
        "styles": [1, "string", 3, "string"],
        "subStates": [2, "doubleStringContent"]
      }
    ],
    "tripleQuotedStringRule": [
      {
        "pattern": "\"\"\"",
        "style": "string",
        "state": "tripleDoubleQuoted"
      }
    ],
    "singleQuotedStringRule": [
      {
        "pattern": "(')((?:[^'\\\\]|\\\\.)*)(')",
        "styles": [1, "string", 3, "string"],
        "subStates": [2, "singleStringContent"]
      }
    ],
    "stringEscapeRule": [
      {
        "pattern": "\\\\.",
        "style": "string"
      }
    ],
    "sigilSlashRule": [
      {
        "pattern": "(~[a-zA-Z]+)(/)",
        "styles": [1, "annotation", 2, "punctuation"],
        "state": "sigilSlash"
      }
    ],
    "sigilParenRule": [
      {
        "pattern": "(~[a-zA-Z]+)(\\()",
        "styles": [1, "annotation", 2, "punctuation"],
        "state": "sigilParen"
      }
    ],
    "sigilDoubleQuotedRule": [
      {
        "pattern": "(~[a-zA-Z]+)(\")",
        "styles": [1, "annotation", 2, "punctuation"],
        "state": "sigilDoubleQuoted"
      }
    ]
  },
  "states": {
    "default": [
      {
        "include": "lineCommentRule"
      },
      {
        "pattern": "(\\@)(${identifier}(?:\\.${identifier})*)",
        "styles": [1, "punctuation", 2, "annotation"]
      },
      {
        "pattern": "(#)(\\{)",
        "styles": [1, "punctuation", 2, "punctuation"]
      },
      {
        "pattern": "(#)([A-Z][A-Z0-9_]*)(\\b)",
        "styles": [1, "punctuation", 2, "macro", 3, "punctuation"]
      },
      {
        "pattern": "\\b(defmodule)\\b${whiteSpace}+(${moduleIdentifier})${whiteSpace}+\\b(do)\\b",
        "styles": [1, "keyword", 2, "class", 3, "keyword"]
      },
      {
        "pattern": "\\b(defmodule)\\b${whiteSpace}+(${moduleIdentifier})",
        "styles": [1, "keyword", 2, "class"]
      },
      {
        "pattern": "\\b(defprotocol|defimpl)\\b${whiteSpace}+(${moduleIdentifier})",
        "styles": [1, "keyword", 2, "class"]
      },
      {
        "pattern": "\\bdefstruct\\b",
        "style": "keyword"
      },
      {
        "pattern": "\\b(defguardp?|defmacrop?|defp|def)\\b${whiteSpace}+(${identifier})${whiteSpace}*(\\()",
        "styles": [1, "keyword", 2, "method", 3, "punctuation"],
        "state": "funcParams"
      },
      {
        "pattern": "\\b(defguardp?|defmacrop?|defp|def)\\b${whiteSpace}+(${identifier})",
        "styles": [1, "keyword", 2, "method"]
      },
      {
        "pattern": "\\b(alias|import|require|use)\\b${whiteSpace}+(${moduleIdentifier})",
        "styles": [1, "keyword", 2, "class"]
      },
      {
        "pattern": "\\b(?:defmodule|defprotocol|defimpl|defstruct|defexception|defdelegate|defmacro|defmacrop|defp|defguard|defguardp|def|alias|import|require|use|quote|unquote|unquote_splicing|case|cond|with|receive|if|unless|for|try|rescue|catch|after|do|end|fn|and|or|not|when|super)\\b",
        "style": "keyword"
      },
      {
        "pattern": "\\b(?:true|false|nil)\\b",
        "style": "builtin"
      },
      {
        "pattern": "\\b(?:__MODULE__|__DIR__|__ENV__|__CALLER__|__STACKTRACE__)\\b",
        "style": "builtin"
      },
      {
        "pattern": "(${moduleIdentifier})(\\.)([a-z_][A-Za-z0-9_]*[!?]?)(\\()",
        "styles": [1, "class", 2, "punctuation", 3, "method", 4, "punctuation"]
      },
      {
        "pattern": "(${moduleIdentifier})(\\.)([a-z_][A-Za-z0-9_]*[!?]?)",
        "styles": [1, "class", 2, "punctuation", 3, "method"]
      },
      {
        "pattern": "${moduleIdentifier}",
        "style": "class"
      },
      {
        "pattern": "(${identifier})(\\()",
        "styles": [1, "method", 2, "punctuation"]
      },
      {
        "pattern": "${identifier}",
        "style": "variable"
      },
      {
        "pattern": "(:)(\"(?:[^\"\\\\]|\\\\.)*\"|${atomIdentifier})",
        "styles": [1, "punctuation", 2, "property"]
      },
      {
        "pattern": "\\b0[xX][0-9a-fA-F_]+\\b",
        "style": "number"
      },
      {
        "pattern": "\\b0[bB][01_]+\\b",
        "style": "number"
      },
      {
        "pattern": "\\b0[oO][0-7_]+\\b",
        "style": "number"
      },
      {
        "pattern": "\\b[0-9][0-9_]*\\.[0-9_]+(?:[eE][+-]?[0-9_]+)?\\b",
        "style": "number"
      },
      {
        "pattern": "\\b[0-9][0-9_]*(?:[eE][+-]?[0-9_]+)?\\b",
        "style": "number"
      },
      {
        "include": "tripleQuotedStringRule"
      },
      {
        "include": "doubleQuotedStringRule"
      },
      {
        "include": "singleQuotedStringRule"
      },
      {
        "include": "sigilSlashRule"
      },
      {
        "include": "sigilParenRule"
      },
      {
        "include": "sigilDoubleQuotedRule"
      },
      {
        "pattern": "[\\[\\]{}(),.]",
        "style": "punctuation"
      },
      {
        "pattern": "->|\\\\|\\\\||&&|\\|>|\\|\\||\\?\\?|===|!==|==|!=|<=|>=|<>|===|<<<|>>>|<\\||\\|>|\\+\\+|--|\\+|-|\\*|/|\\\\|%|=|<|>|!|&|\\||\\^|~|\\.",
        "style": "punctuation"
      }
    ],
    "funcParams": [
      {
        "pattern": "\\)",
        "style": "punctuation",
        "state": "default"
      },
      {
        "pattern": "\\b(?:when|and|or|not|in|do|else|catch|rescue|after)\\b",
        "style": "keyword"
      },
      {
        "pattern": "(${identifier})${whiteSpace}*(:)${whiteSpace}*(${moduleIdentifier})",
        "styles": [1, "variable", 2, "punctuation", 3, "class"]
      },
      {
        "pattern": "(${identifier})${whiteSpace}*(:)${whiteSpace}*(${identifier})",
        "styles": [1, "variable", 2, "punctuation", 3, "variable"]
      },
      {
        "pattern": "(${identifier})${whiteSpace}*([=,])",
        "styles": [1, "variable", 2, "punctuation"]
      },
      {
        "pattern": "${identifier}",
        "style": "variable"
      },
      {
        "pattern": "\\b(?:true|false|nil)\\b",
        "style": "builtin"
      },
      {
        "include": "doubleQuotedStringRule"
      },
      {
        "include": "singleQuotedStringRule"
      },
      {
        "include": "sigilParenRule"
      },
      {
        "include": "sigilSlashRule"
      },
      {
        "include": "sigilDoubleQuotedRule"
      },
      {
        "pattern": "\\b0[xX][0-9a-fA-F_]+\\b",
        "style": "number"
      },
      {
        "pattern": "\\b0[bB][01_]+\\b",
        "style": "number"
      },
      {
        "pattern": "\\b[0-9][0-9_]*\\.[0-9_]+(?:[eE][+-]?[0-9_]+)?\\b",
        "style": "number"
      },
      {
        "pattern": "\\b[0-9][0-9_]*(?:[eE][+-]?[0-9_]+)?\\b",
        "style": "number"
      },
      {
        "pattern": "[,\\[\\]{}()=]",
        "style": "punctuation"
      },
      {
        "onLineEndState": "funcParams"
      }
    ],
    "doubleStringContent": [
      {
        "pattern": "#\\{[^}]*\\}",
        "style": "annotation"
      },
      {
        "include": "urlRule"
      },
      {
        "include": "stringEscapeRule"
      },
      {
        "pattern": "${any}",
        "style": "string"
      }
    ],
    "singleStringContent": [
      {
        "include": "urlRule"
      },
      {
        "include": "stringEscapeRule"
      },
      {
        "pattern": "${any}",
        "style": "string"
      }
    ],
    "sigilSlash": [
      {
        "pattern": "/",
        "style": "string",
        "state": "default"
      },
      {
        "pattern": "#\\{[^}]*\\}",
        "style": "annotation"
      },
      {
        "include": "urlRule"
      },
      {
        "include": "stringEscapeRule"
      },
      {
        "pattern": "${any}",
        "style": "string"
      }
    ],
    "sigilParen": [
      {
        "pattern": "\\)",
        "style": "string",
        "state": "default"
      },
      {
        "pattern": "#\\{[^}]*\\}",
        "style": "annotation"
      },
      {
        "include": "urlRule"
      },
      {
        "include": "stringEscapeRule"
      },
      {
        "pattern": "${any}",
        "style": "string"
      }
    ],
    "sigilDoubleQuoted": [
      {
        "pattern": "\"",
        "style": "string",
        "state": "default"
      },
      {
        "pattern": "#\\{[^}]*\\}",
        "style": "annotation"
      },
      {
        "include": "urlRule"
      },
      {
        "include": "stringEscapeRule"
      },
      {
        "pattern": "${any}",
        "style": "string"
      }
    ],
    "tripleDoubleQuoted": [
      {
        "pattern": "\"\"\"",
        "style": "string",
        "state": "default"
      },
      {
        "pattern": "#\\{[^}]*\\}",
        "style": "annotation"
      },
      {
        "include": "urlRule"
      },
      {
        "include": "stringEscapeRule"
      },
      {
        "pattern": "${any}",
        "style": "string"
      }
    ],
    "lineCommentContent": [
      {
        "include": "urlRule"
      },
      {
        "pattern": "${any}",
        "style": "comment"
      }
    ]
  },
  "scopeRules": {
    "skips": [
      { "kind": "lineComment", "start": "#" },
      { "kind": "string", "start": "\"", "end": "\"", "escape": "\\" },
      { "kind": "string", "start": "'", "end": "'", "escape": "\\" }
    ],
    "rules": [
      { "kind": "word", "start": "do", "end": "end", "branches": ["else","catch","rescue","after"] },
      { "kind": "word", "start": "fn", "end": "end" }
    ]
  }
}
