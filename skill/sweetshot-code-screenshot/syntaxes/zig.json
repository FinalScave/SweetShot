{
  "name": "zig",
  "fileSuffixes": [".zig", ".zon"],
  "variables": {
    "identifier": "[a-zA-Z_][a-zA-Z0-9_]*",
    "typeIdentifier": "[A-Z][A-Za-z0-9_]*[a-z][A-Za-z0-9_]*",
    "builtinIntegerType": "[iu][1-9][0-9]*",
    "builtinType": "allowzero|anyerror|anyframe|anyopaque|anytype|bool|c_char|c_int|c_long|c_longdouble|c_longlong|c_short|c_uint|c_ulong|c_ulonglong|c_ushort|comptime_float|comptime_int|f128|f16|f32|f64|f80|i0|u0|isize|linksection|noreturn|type|usize|void|volatile",
    "whiteSpace": "[ \\t\\f]",
    "any": "[\\S\\s]"
  },
  "fragments": {
    "lineCommentRule": [
      {
        "pattern": "(//)(.*)",
        "styles": [1, "comment", 2, "comment"],
        "subStates": [2, "lineCommentContent"]
      }
    ],
    "docCommentRule": [
      {
        "pattern": "(?m)^(\\s*)(///|//!)(.*)",
        "styles": [2, "comment", 3, "comment"],
        "subStates": [3, "lineCommentContent"]
      }
    ],
    "doubleQuotedStringRule": [
      {
        "pattern": "(c?\")((?:[^\"]|\\\\.)*)(\")",
        "styles": [1, "string", 3, "string"],
        "subStates": [2, "stringContent"]
      }
    ]
  },
  "states": {
    "default": [
      {
        "include": "docCommentRule"
      },
      {
        "include": "lineCommentRule"
      },
      {
        "pattern": "\\b_\\b",
        "style": "variable"
      },
      {
        "pattern": "\\b(true|false|null)\\b",
        "styles": [1, "builtin"]
      },
      {
        "pattern": "\\b(undefined|unreachable)\\b",
        "styles": [1, "keyword"]
      },
      {
        "pattern": "\\b(var|const|comptime|threadlocal)\\b",
        "styles": [1, "keyword"]
      },
      {
        "pattern": "\\b(const|var)\\b(\\s+)(${typeIdentifier})(\\s*)(=)(\\s*)(struct|enum|union|opaque|error)\\b",
        "styles": [1, "keyword", 2, "punctuation", 3, "class", 5, "punctuation", 7, "keyword"]
      },
      {
        "pattern": "\\b(const|var)\\b(\\s+)(${identifier})(\\s*)(:|=)",
        "styles": [1, "keyword", 2, "punctuation", 3, "variable", 5, "punctuation"]
      },
      {
        "pattern": "\\b(fn)\\b(\\s+)(${identifier})(\\s*)(\\()",
        "styles": [1, "keyword", 2, "punctuation", 3, "method", 5, "punctuation"]
      },
      {
        "pattern": "\\b(if|else|switch|while|for|and|or|orelse|error|fn|try|test|pub|usingnamespace|return|break|continue)\\b",
        "styles": [1, "keyword"]
      },
      {
        "pattern": "\\b(struct|enum|union|error|packed|opaque)\\b",
        "styles": [1, "keyword"]
      },
      {
        "pattern": "\\b(defer|errdefer|async|nosuspend|await|suspend|resume|export|extern|catch|inline|noinline|asm|callconv|noalias)\\b",
        "styles": [1, "keyword"]
      },
      {
        "pattern": "\\b(align)\\b",
        "styles": [1, "keyword"]
      },
      {
        "pattern": "\\b(${builtinIntegerType})\\b",
        "styles": [1, "builtin"]
      },
      {
        "pattern": "\\b(${builtinType})\\b",
        "styles": [1, "builtin"]
      },
      {
        "pattern": "(?m)^(\\s*)(${identifier})(\\s*)(:)",
        "styles": [2, "property", 4, "punctuation"]
      },
      {
        "pattern": "([,(])(\\s*)(${identifier})(\\s*)(:)",
        "styles": [1, "punctuation", 3, "variable", 5, "punctuation"]
      },
      {
        "pattern": "(@)(Frame|OpaqueType|TagType|This|Type|TypeOf|Vector|abs|addWithOverflow|alignCast|alignOf|as|asyncCall|atomicLoad|atomicRmw|atomicStore|bitCast|bitOffsetOf|bitReverse|bitSizeOf|breakpoint|byteOffsetOf|byteSwap|cDefine|cImport|cInclude|cUndef|call|ceil|clz|cmpxchgStrong|cmpxchgWeak|compileError|compileLog|constCast|cos|ctz|divExact|divFloor|divTrunc|embedFile|enumFromInt|errorCast|errorFromInt|errorName|errorReturnTrace|exp|exp2|export|extern|fence|field|fieldParentPtr|floatCast|floatFromInt|floor|frame|frameAddress|frameSize|hasDecl|hasField|import|inComptime|intCast|intFromBool|intFromEnum|intFromError|intFromFloat|intFromPtr|log|log10|log2|max|memcpy|memset|min|mod|mulAdd|mulWithOverflow|newStackCall|offsetOf|panic|popCount|prefetch|ptrCast|ptrFromInt|reduce|rem|returnAddress|round|select|setAlignStack|setCold|setEvalBranchQuota|setFloatMode|setRuntimeSafety|shlExact|shlWithOverflow|shrExact|shuffle|sin|sizeOf|splat|sqrt|src|subWithOverflow|tagName|tan|trap|trunc|truncate|typeInfo|typeName|unionInit|volatileCast|wasmMemoryGrow|wasmMemorySize)\\b",
        "styles": [1, "punctuation", 2, "method"]
      },
      {
        "pattern": "(${typeIdentifier})(\\.)([a-zA-Z_][a-zA-Z0-9_]*)(\\.)([a-zA-Z_][a-zA-Z0-9_]*)(\\()",
        "styles": [1, "class", 2, "punctuation", 3, "property", 4, "punctuation", 5, "method", 6, "punctuation"]
      },
      {
        "pattern": "(${identifier})(\\.)([a-zA-Z_][a-zA-Z0-9_]*)(\\.)([a-zA-Z_][a-zA-Z0-9_]*)(\\()",
        "styles": [1, "variable", 2, "punctuation", 3, "property", 4, "punctuation", 5, "method", 6, "punctuation"]
      },
      {
        "pattern": "(${identifier})(\\.)([a-zA-Z_][a-zA-Z0-9_]*)(\\.)(${typeIdentifier})\\b",
        "styles": [1, "variable", 2, "punctuation", 3, "property", 4, "punctuation", 5, "class"]
      },
      {
        "pattern": "(${typeIdentifier})(\\.)([a-zA-Z_][a-zA-Z0-9_]*)(\\()",
        "styles": [1, "class", 2, "punctuation", 3, "method", 4, "punctuation"]
      },
      {
        "pattern": "(${identifier})(\\.)(${typeIdentifier})\\b",
        "styles": [1, "variable", 2, "punctuation", 3, "class"]
      },
      {
        "pattern": "(${identifier})(\\.)([a-zA-Z_][a-zA-Z0-9_]*)(\\()",
        "styles": [1, "variable", 2, "punctuation", 3, "method", 4, "punctuation"]
      },
      {
        "pattern": "(\\.)(${typeIdentifier})\\b",
        "styles": [1, "punctuation", 2, "class"]
      },
      {
        "pattern": "(\\.)([a-zA-Z_][a-zA-Z0-9_]*)(\\()",
        "styles": [1, "punctuation", 2, "method", 3, "punctuation"]
      },
      {
        "pattern": "(${identifier})(\\.)([a-zA-Z_][a-zA-Z0-9_]*)",
        "styles": [1, "variable", 2, "punctuation", 3, "property"]
      },
      {
        "pattern": "(\\.)([a-zA-Z_][a-zA-Z0-9_]*)",
        "styles": [1, "punctuation", 2, "property"]
      },
      {
        "pattern": "(${typeIdentifier})\\b",
        "styles": [1, "class"]
      },
      {
        "pattern": "(${identifier})(\\()",
        "styles": [1, "method", 2, "punctuation"]
      },
      {
        "pattern": "(b?')((?:[^'\\\\]|\\\\.)*?)(')",
        "styles": [1, "string", 3, "string"],
        "subStates": [2, "charContent"]
      },
      {
        "pattern": "(?m)^(\\s*)(\\\\\\\\.*)$",
        "styles": [2, "string"]
      },
      {
        "include": "doubleQuotedStringRule"
      },
      {
        "pattern": "(\\b0[xX][0-9a-fA-F_]+(?:\\.[0-9a-fA-F_]+)?(?:[pP][+-]?[0-9_]+)\\b)",
        "styles": [1, "number"]
      },
      {
        "pattern": "(\\b0[xX][0-9a-fA-F_]+\\b)",
        "styles": [1, "number"]
      },
      {
        "pattern": "(\\b0[oO][0-7_]+\\b)",
        "styles": [1, "number"]
      },
      {
        "pattern": "(\\b0[bB][01_]+\\b)",
        "styles": [1, "number"]
      },
      {
        "pattern": "(\\b(?:[0-9][0-9_]*\\.[0-9_]+(?:[eE][+-]?[0-9_]+)?|[0-9][0-9_]*(?:[eE][+-]?[0-9_]+))\\b)",
        "styles": [1, "number"]
      },
      {
        "pattern": "(\\b[0-9][0-9_]*\\b)",
        "styles": [1, "number"]
      },
      {
        "pattern": "(\\.\\.\\.?|<<=|>>=|<<|>>|\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|==|!=|<=|>=|=>|->|&&|\\|\\||[-+/*=^&?|!<>%~:])",
        "styles": [1, "punctuation"]
      },
      {
        "pattern": "[()\\[\\]{};,.]",
        "style": "punctuation"
      },
      {
        "pattern": "(${identifier})",
        "styles": [1, "variable"]
      }
    ],
    "stringContent": [
      {
        "pattern": "\\\\([nrt\\\\'\"]|x[0-9a-fA-F]{2}|u[0-9a-fA-F]{4}|U[0-9a-fA-F]{6})",
        "style": "string"
      },
      {
        "pattern": "\\\\.",
        "style": "string"
      },
      {
        "pattern": "${any}",
        "style": "string"
      }
    ],
    "charContent": [
      {
        "pattern": "\\\\([nrt\\\\']|x[0-9a-fA-F]{2}|u[0-9a-fA-F]{4}|U[0-9a-fA-F]{6})",
        "style": "string"
      },
      {
        "pattern": "\\\\.",
        "style": "string"
      },
      {
        "pattern": "[^']",
        "style": "string"
      }
    ],
    "lineCommentContent": [
      {
        "pattern": "${any}",
        "style": "comment"
      }
    ]
  }
}
