{
  "name": "abnf",
  "fileSuffixes": [".abnf"],
  "variables": {
    "identifier": "[a-zA-Z][a-zA-Z0-9-]*",
    "whiteSpace": "[ \\t\\f]",
    "any": "[\\S\\s]"
  },
  "fragments": {
    "lineCommentRule": [
      {
        "pattern": "(;)(.*)",
        "styles": [1, "comment", 2, "comment"],
        "subStates": [2, "lineCommentContent"]
      }
    ]
  },
  "states": {
    "default": [
      {
        "pattern": "(<)([^>]*)(>)",
        "styles": [1, "string", 2, "string", 3, "string"]
      },
      {
        "pattern": "(\\[)",
        "styles": [1, "punctuation"],
        "state": "optionalGroup"
      },
      {
        "pattern": "(\\])",
        "styles": [1, "punctuation"]
      },
      {
        "pattern": "(%[bsix])(\")((?:[^\"\\\\]|\\\\.)*)(\")",
        "styles": [1, "string", 2, "string", 4, "string"],
        "subStates": [3, "stringContent"]
      },
      {
        "pattern": "(\")((?:[^\"\\\\]|\\\\.)*)(\")",
        "styles": [1, "string", 3, "string"],
        "subStates": [2, "stringContent"]
      },
      {
        "pattern": "(%)([bsix])([0-9a-fA-F.]+(?:-[0-9a-fA-F.]+)?)",
        "styles": [1, "number", 2, "number", 3, "number"]
      },
      {
        "pattern": "\\b(\\d+)(\\*)",
        "styles": [1, "number", 2, "number"]
      },
      {
        "pattern": "(\\*)(\\d*)",
        "styles": [1, "number", 2, "number"]
      },
      {
        "pattern": "\\b(\\d+)\\b",
        "styles": [1, "number"]
      },
      {
        "pattern": "(${identifier})(\\s*)(=)",
        "styles": [1, "variable", 2, "punctuation", 3, "punctuation"]
      },
      {
        "pattern": "(${identifier})",
        "styles": [1, "variable"]
      },
      {
        "pattern": "(\\/)",
        "styles": [1, "punctuation"]
      },
      {
        "pattern": "(\\(|\\))",
        "styles": [1, "punctuation"]
      },
      {
        "include": "lineCommentRule"
      }
    ],
    "optionalGroup": [
      {
        "pattern": "(\\])",
        "styles": [1, "punctuation"],
        "state": "default"
      },
      {
        "pattern": "(<)([^>]*)(>)",
        "styles": [1, "string", 2, "string", 3, "string"]
      },
      {
        "pattern": "(\\[)",
        "styles": [1, "punctuation"],
        "state": "optionalGroup"
      },
      {
        "pattern": "(%[bsix])(\")((?:[^\"\\\\]|\\\\.)*)(\")",
        "styles": [1, "string", 2, "string", 4, "string"],
        "subStates": [3, "stringContent"]
      },
      {
        "pattern": "(\")((?:[^\"\\\\]|\\\\.)*)(\")",
        "styles": [1, "string", 3, "string"],
        "subStates": [2, "stringContent"]
      },
      {
        "pattern": "(%)([bsix])([0-9a-fA-F.]+(?:-[0-9a-fA-F.]+)?)",
        "styles": [1, "number", 2, "number", 3, "number"]
      },
      {
        "pattern": "\\b(\\d+)(\\*)",
        "styles": [1, "number", 2, "number"]
      },
      {
        "pattern": "(\\*)(\\d*)",
        "styles": [1, "number", 2, "number"]
      },
      {
        "pattern": "\\b(\\d+)\\b",
        "styles": [1, "number"]
      },
      {
        "pattern": "(${identifier})",
        "styles": [1, "variable"]
      },
      {
        "pattern": "(\\/)",
        "styles": [1, "punctuation"]
      },
      {
        "pattern": "(\\(|\\))",
        "styles": [1, "punctuation"]
      },
      {
        "include": "lineCommentRule"
      },
      {
        "onLineEndState": "default"
      }
    ],
    "stringContent": [
      {
        "pattern": "${any}",
        "style": "string"
      }
    ],
    "lineCommentContent": [
      {
        "pattern": "${any}",
        "style": "comment"
      }
    ]
  }
}
