{
  "name": "fsharp",
  "fileSuffixes": [".fs", ".fsi", ".fsx"],
  "variables": {
    "identifier": "[a-zA-Z_]\\w*",
    "quotedIdentifier": "``[^`]+``",
    "typeParameter": "'[_a-zA-Z]\\w*",
    "whiteSpace": "[ \\t\\f]",
    "any": "[\\S\\s]",
    "builtinType": "int|int8|int16|int32|int64|uint8|uint16|uint32|uint64|float|float32|decimal|char|string|bool|unit|list|array|seq|option|Result|Async|Task|Lazy|Map|Set|dict|bigint|nativeint|unativeint|byref|nativeptr|void|exn|FSharpList|FSharpMap|FSharpSet|ResizeArray"
  },
  "fragments": {
    "urlRule": [
      {
        "pattern": "(?:(?:https?|ftp)://|www\\.)[A-Za-z0-9._~:/?#\\[\\]@!$&()*+,;=%-]*[A-Za-z0-9_~/#@%=+-]",
        "style": "url"
      }
    ],
    "classIdentifierRule": [
      {
        "pattern": "${quotedIdentifier}",
        "style": "class"
      },
      {
        "pattern": "${identifier}",
        "style": "class"
      }
    ],
    "typeParameterRule": [
      {
        "pattern": "${typeParameter}",
        "style": "class"
      }
    ],
    "quotedIdentifierVariableRule": [
      {
        "pattern": "${quotedIdentifier}",
        "style": "variable"
      }
    ],
    "quotedIdentifierMethodRule": [
      {
        "pattern": "${quotedIdentifier}",
        "style": "method"
      }
    ],
    "stringTerminatorToDefaultRule": [
      {
        "pattern": "\"",
        "style": "string",
        "state": "default"
      }
    ],
    "stringAnyCharRule": [
      {
        "pattern": "${any}",
        "style": "string"
      }
    ],
    "doubleQuotedStringRule": [
      {
        "pattern": "(\")((?:[^\"\\\\]|\\\\.)*)(\")",
        "styles": [1, "string", 3, "string"],
        "subStates": [2, "doubleStringContent"]
      }
    ],
    "docLineCommentRule": [
      {
        "pattern": "(///)(.*)",
        "styles": [1, "comment", 2, "comment"],
        "subStates": [2, "lineCommentContent"]
      }
    ],
    "lineCommentRule": [
      {
        "pattern": "(//)(.*)",
        "styles": [1, "comment", 2, "comment"],
        "subStates": [2, "lineCommentContent"]
      }
    ],
    "commonUnionCaseRule": [
      {
        "pattern": "\\b(Some|None|Ok|Error)\\b",
        "style": "builtin"
      }
    ]
  },
  "states": {
    "default": [
      {
        "pattern": "\\(\\*",
        "style": "comment",
        "state": "blockComment"
      },
      {
        "includes": ["docLineCommentRule", "lineCommentRule"]
      },
      {
        "pattern": "^${whiteSpace}*(#)${whiteSpace}*(if|else|endif|light|nowarn|warn|r|load|time|include|require|ifnot|const)\\b",
        "styles": [1, "preprocessor", 2, "preprocessor"]
      },
      {
        "pattern": "(\\[<)(.*?)(>\\])",
        "styles": [1, "punctuation", 2, "annotation", 3, "punctuation"],
        "subStates": [2, "attributeContent"]
      },
      {
        "pattern": "(namespace)${whiteSpace}+(${identifier}(?:\\.${identifier})*)",
        "styles": [1, "keyword", 2, "class"]
      },
      {
        "pattern": "(module)${whiteSpace}+(${identifier}(?:\\.${identifier})*)",
        "styles": [1, "keyword", 2, "class"]
      },
      {
        "pattern": "(open)${whiteSpace}+(${identifier}(?:\\.${identifier})*)",
        "styles": [1, "keyword", 2, "class"]
      },
      {
        "pattern": "(let|let!)${whiteSpace}+(rec)\\b${whiteSpace}+(\\(\\|.*?\\|\\))",
        "styles": [1, "keyword", 2, "keyword", 3, "method"]
      },
      {
        "pattern": "(let|let!|use|use!|member|override|abstract|static)${whiteSpace}+(\\(\\|.*?\\|\\))",
        "styles": [1, "keyword", 2, "method"]
      },
      {
        "pattern": "(let|let!)${whiteSpace}+(rec)\\b${whiteSpace}+(${quotedIdentifier})${whiteSpace}*(\\()",
        "styles": [1, "keyword", 2, "keyword", 3, "method", 4, "punctuation"],
        "state": "funcParams"
      },
      {
        "pattern": "(let|let!)${whiteSpace}+(rec)\\b${whiteSpace}+(${quotedIdentifier})",
        "styles": [1, "keyword", 2, "keyword", 3, "method"]
      },
      {
        "pattern": "(type)${whiteSpace}+(${identifier})${whiteSpace}*(<)([^()]*)(>)",
        "styles": [1, "keyword", 2, "class", 3, "punctuation", 5, "punctuation"],
        "subStates": [4, "genericType"],
        "state": "typeHeader"
      },
      {
        "pattern": "(type)${whiteSpace}+(${identifier})",
        "styles": [1, "keyword", 2, "class"],
        "state": "typeHeader"
      },
      {
        "pattern": "(let|let!)${whiteSpace}+(rec)\\b${whiteSpace}+(${identifier})${whiteSpace}*(\\()",
        "styles": [1, "keyword", 2, "keyword", 3, "method", 4, "punctuation"],
        "state": "funcParams"
      },
      {
        "pattern": "(let|let!)${whiteSpace}+(rec)\\b${whiteSpace}+(${identifier})",
        "styles": [1, "keyword", 2, "keyword", 3, "method"]
      },
      {
        "pattern": "(let|let!|use|use!|member|override|abstract|static)${whiteSpace}+(inline)\\b${whiteSpace}+(${identifier})${whiteSpace}*(\\()",
        "styles": [1, "keyword", 2, "keyword", 3, "method", 4, "punctuation"],
        "state": "funcParams"
      },
      {
        "pattern": "(let|let!|use|use!|member|override|abstract|static)${whiteSpace}+(inline)\\b${whiteSpace}+(${quotedIdentifier})${whiteSpace}*(\\()",
        "styles": [1, "keyword", 2, "keyword", 3, "method", 4, "punctuation"],
        "state": "funcParams"
      },
      {
        "pattern": "(let|let!|use|use!|member|override|abstract|static)${whiteSpace}+(inline)\\b${whiteSpace}+(${identifier})",
        "styles": [1, "keyword", 2, "keyword", 3, "method"]
      },
      {
        "pattern": "(let|let!|use|use!|member|override|abstract|static)${whiteSpace}+(inline)\\b${whiteSpace}+(${quotedIdentifier})",
        "styles": [1, "keyword", 2, "keyword", 3, "method"]
      },
      {
        "pattern": "(member|override|abstract)${whiteSpace}+(${identifier})(\\.)(${identifier})${whiteSpace}*(\\()",
        "styles": [1, "keyword", 2, "variable", 3, "punctuation", 4, "method", 5, "punctuation"],
        "state": "funcParams"
      },
      {
        "pattern": "(member|override|abstract)${whiteSpace}+(${identifier})(\\.)(${identifier})",
        "styles": [1, "keyword", 2, "variable", 3, "punctuation", 4, "method"]
      },
      {
        "pattern": "(let|let!|use|use!|member|override|abstract|static)${whiteSpace}+(${identifier})${whiteSpace}*(\\()",
        "styles": [1, "keyword", 2, "method", 3, "punctuation"],
        "state": "funcParams"
      },
      {
        "pattern": "(let|let!|use|use!|member|override|abstract|static)${whiteSpace}+(${quotedIdentifier})${whiteSpace}*(\\()",
        "styles": [1, "keyword", 2, "method", 3, "punctuation"],
        "state": "funcParams"
      },
      {
        "pattern": "(let|let!|use|use!|member|override|abstract|static)${whiteSpace}+(${identifier})",
        "styles": [1, "keyword", 2, "variable"]
      },
      {
        "pattern": "(let|let!|use|use!|member|override|abstract|static)${whiteSpace}+(${quotedIdentifier})",
        "styles": [1, "keyword", 2, "variable"]
      },
      {
        "pattern": "(val)${whiteSpace}+(${identifier})",
        "styles": [1, "keyword", 2, "variable"]
      },
      {
        "pattern": "(mutable)${whiteSpace}+(${identifier})",
        "styles": [1, "keyword", 2, "variable"]
      },
      {
        "pattern": "\\b(and|as|assert|base|begin|class|default|delegate|do|done|downcast|downto|elif|else|end|exception|extern|finally|fixed|for|fun|function|global|if|in|inherit|inline|interface|internal|lazy|let|match|member|module|mutable|namespace|new|not|null|of|open|or|override|private|public|rec|return|static|struct|then|to|try|type|upcast|use|val|void|when|while|with|yield|const|do!)\\b",
        "styles": [1, "keyword"]
      },
      {
        "pattern": "(let!|use!|return!|yield!|match!)\\b",
        "styles": [1, "keyword"]
      },
      {
        "pattern": "\\b(${builtinType})\\b",
        "styles": [1, "builtin"]
      },
      {
        "pattern": "\\b(true|false)\\b",
        "styles": [1, "builtin"]
      },
      {
        "include": "commonUnionCaseRule"
      },
      {
        "include": "typeParameterRule"
      },
      {
        "include": "quotedIdentifierVariableRule"
      },
      {
        "pattern": "\\$\"\"\"",
        "style": "string",
        "state": "interpolatedTripleString"
      },
      {
        "pattern": "\"\"\"",
        "style": "string",
        "state": "tripleString"
      },
      {
        "pattern": "\\$@\"",
        "style": "string",
        "state": "interpolatedVerbatimString"
      },
      {
        "pattern": "@\"",
        "style": "string",
        "state": "verbatimString"
      },
      {
        "pattern": "\\$\"",
        "style": "string",
        "state": "interpolatedString"
      },
      {
        "include": "doubleQuotedStringRule"
      },
      {
        "pattern": "'[^'\\\\]'|'\\\\.'|'\\\\u[0-9a-fA-F]{4}'|'\\\\U[0-9a-fA-F]{8}'",
        "style": "string"
      },
      {
        "pattern": "\\b0[xX][0-9a-fA-F_]+(?:[eE][+-]?[0-9_]+)?[FLDRZiy]?\\b",
        "style": "number"
      },
      {
        "pattern": "\\b0[oO][0-7_]+[FLDRZiy]?\\b",
        "style": "number"
      },
      {
        "pattern": "\\b0[bB][01_]+[FLDRZiy]?\\b",
        "style": "number"
      },
      {
        "pattern": "\\b(?:[0-9][0-9_]*\\.?[0-9_]*(?:[eE][+-]?[0-9_]+)?[FLDRZiy]?)\\b",
        "style": "number"
      },
      {
        "pattern": "(${identifier})(\\.)(${identifier})${whiteSpace}*(\\()",
        "styles": [1, "class", 2, "punctuation", 3, "method", 4, "punctuation"]
      },
      {
        "pattern": "(${identifier})(\\.)(${identifier})",
        "styles": [1, "variable", 2, "punctuation", 3, "variable"]
      },
      {
        "pattern": "(${identifier})${whiteSpace}*(<)([^()]*)(>)",
        "styles": [1, "class", 2, "punctuation", 4, "punctuation"],
        "subStates": [3, "genericType"]
      },
      {
        "pattern": "(${quotedIdentifier})${whiteSpace}*(<)([^()]*)(>)",
        "styles": [1, "class", 2, "punctuation", 4, "punctuation"],
        "subStates": [3, "genericType"]
      },
      {
        "pattern": "(${identifier})${whiteSpace}*(\\()",
        "styles": [1, "method", 2, "punctuation"],
        "state": "funcParams"
      },
      {
        "pattern": "(${quotedIdentifier})${whiteSpace}*(\\()",
        "styles": [1, "method", 2, "punctuation"],
        "state": "funcParams"
      },
      {
        "pattern": "->|<-|=>|\\|>|>>|<<|<\\||::|:>\\?|:>|:\\?|\\|\\|>|\\|\\|\\|>|<<<|>>>|&&&|\\|\\|\\||^^^|~~~|\\*\\*|:=|<>|<=|>=|==|!=|&&|\\|\\||[.()\\[\\]!?@%^&|+\\-*/<>=,{};:~#]",
        "style": "punctuation"
      }
    ],
    "typeHeader": [
      {
        "pattern": "(<)(.*?)(>)",
        "styles": [1, "punctuation", 3, "punctuation"],
        "subStates": [2, "genericType"]
      },
      {
        "pattern": "\\b(of|inherit|interface|with|and|when|where|static|member|override|abstract|private|public|internal|mutable|inline|rec|val|new|delegate|struct|enum|union|exception|requires)\\b",
        "styles": [1, "keyword"]
      },
      {
        "pattern": "\\b(${builtinType})\\b",
        "styles": [1, "builtin"]
      },
      {
        "pattern": "(${identifier})${whiteSpace}*(<)(.*?)(>)",
        "styles": [1, "class", 2, "punctuation", 4, "punctuation"],
        "subStates": [3, "genericType"]
      },
      {
        "pattern": "(${identifier})${whiteSpace}*(\\()",
        "styles": [1, "class", 2, "punctuation"],
        "state": "funcParams"
      },
      {
        "include": "classIdentifierRule"
      },
      {
        "pattern": "[,()\\[\\]*&|+\\-<>=]",
        "style": "punctuation"
      },
      {
        "pattern": "[={;]",
        "style": "punctuation",
        "state": "default"
      },
      {
        "onLineEndState": "default"
      }
    ],
    "funcParams": [
      {
        "pattern": "\\)",
        "style": "punctuation",
        "state": "default"
      },
      {
        "pattern": "\\b(${builtinType})\\b",
        "styles": [1, "builtin"]
      },
      {
        "include": "typeParameterRule"
      },
      {
        "pattern": "\\b(mutable|byref|out|inline|private|internal|public)\\b",
        "styles": [1, "keyword"]
      },
      {
        "pattern": "(${quotedIdentifier})${whiteSpace}*(:)${whiteSpace}*(${identifier})${whiteSpace}*(<)([^()]*)(>)",
        "styles": [1, "variable", 2, "punctuation", 3, "class", 4, "punctuation", 6, "punctuation"],
        "subStates": [5, "genericType"]
      },
      {
        "pattern": "(${identifier})${whiteSpace}*(:)${whiteSpace}*(${identifier})${whiteSpace}*(<)([^()]*)(>)",
        "styles": [1, "variable", 2, "punctuation", 3, "class", 4, "punctuation", 6, "punctuation"],
        "subStates": [5, "genericType"]
      },
      {
        "pattern": "(${quotedIdentifier})${whiteSpace}*(:)${whiteSpace}*(${identifier})",
        "styles": [1, "variable", 2, "punctuation", 3, "class"]
      },
      {
        "pattern": "(${identifier})${whiteSpace}*(:)${whiteSpace}*(${identifier})",
        "styles": [1, "variable", 2, "punctuation", 3, "class"]
      },
      {
        "pattern": "(${quotedIdentifier})${whiteSpace}*([=,])",
        "styles": [1, "variable", 2, "punctuation"]
      },
      {
        "pattern": "(${identifier})${whiteSpace}*([=,])",
        "styles": [1, "variable", 2, "punctuation"]
      },
      {
        "pattern": "\\b(true|false)\\b",
        "styles": [1, "builtin"]
      },
      {
        "pattern": "\\b(?:[0-9][0-9_]*\\.?[0-9_]*(?:[eE][+-]?[0-9_]+)?[FLDRZiy]?)\\b",
        "style": "number"
      },
      {
        "include": "doubleQuotedStringRule"
      },
      {
        "pattern": "[,\\[\\]()]",
        "style": "punctuation"
      },
      {
        "onLineEndState": "funcParams"
      }
    ],
    "genericType": [
      {
        "pattern": "\\b(${builtinType})\\b",
        "styles": [1, "builtin"]
      },
      {
        "include": "typeParameterRule"
      },
      {
        "pattern": "(${identifier})${whiteSpace}*(<)([^()]*)(>)",
        "styles": [1, "class", 2, "punctuation", 4, "punctuation"],
        "subStates": [3, "genericType"]
      },
      {
        "include": "classIdentifierRule"
      },
      {
        "pattern": "[,\\[\\]()]",
        "style": "punctuation"
      }
    ],
    "attributeContent": [
      {
        "pattern": "\\b(AllowNullLiteral|AbstractClass|Sealed|Struct|Interface|Class|Literal|Obsolete|Serializable|StructuralComparison|StructuralEquality|CompiledName|CompilerMessage|CustomOperation|EntryPoint|Extension|NoComparison|NoEquality|ReferenceEquality|StructuralTyping|AutoOpen|RequireQualifiedAccess|CLIMutable|CLIEvent|Measure|MeasureAnnotatedAbbrev)\\b",
        "styles": [1, "annotation"]
      },
      {
        "pattern": "(${identifier})${whiteSpace}*(\\()",
        "styles": [1, "annotation", 2, "punctuation"]
      },
      {
        "pattern": "(${identifier})",
        "styles": [1, "annotation"]
      },
      {
        "pattern": "\\b(true|false)\\b",
        "styles": [1, "builtin"]
      },
      {
        "include": "doubleQuotedStringRule"
      },
      {
        "pattern": "[,()\\[\\]]",
        "style": "punctuation"
      }
    ],
    "verbatimString": [
      {
        "pattern": "\"\"",
        "style": "string"
      },
      {
        "includes": ["stringTerminatorToDefaultRule", "urlRule", "stringAnyCharRule"]
      }
    ],
    "interpolatedString": [
      {
        "pattern": "\\{\\{",
        "style": "string"
      },
      {
        "pattern": "\\}\\}",
        "style": "string"
      },
      {
        "pattern": "\\{[^}]*\\}",
        "style": "annotation"
      },
      {
        "pattern": "\\\\.",
        "style": "string"
      },
      {
        "includes": ["stringTerminatorToDefaultRule", "urlRule", "stringAnyCharRule"]
      }
    ],
    "interpolatedVerbatimString": [
      {
        "pattern": "\\{\\{",
        "style": "string"
      },
      {
        "pattern": "\\}\\}",
        "style": "string"
      },
      {
        "pattern": "\\{[^}]*\\}",
        "style": "annotation"
      },
      {
        "pattern": "\"\"",
        "style": "string"
      },
      {
        "includes": ["stringTerminatorToDefaultRule", "urlRule", "stringAnyCharRule"]
      }
    ],
    "tripleString": [
      {
        "pattern": "\"\"\"",
        "style": "string",
        "state": "default"
      },
      {
        "include": "urlRule"
      },
      {
        "include": "stringAnyCharRule"
      }
    ],
    "interpolatedTripleString": [
      {
        "pattern": "\\{\\{",
        "style": "string"
      },
      {
        "pattern": "\\}\\}",
        "style": "string"
      },
      {
        "pattern": "\\{[^}]*\\}",
        "style": "annotation"
      },
      {
        "pattern": "\"\"\"",
        "style": "string",
        "state": "default"
      },
      {
        "include": "urlRule"
      },
      {
        "include": "stringAnyCharRule"
      }
    ],
    "doubleStringContent": [
      {
        "include": "urlRule"
      },
      {
        "pattern": "\\\\.",
        "style": "string"
      },
      {
        "include": "stringAnyCharRule"
      }
    ],
    "lineCommentContent": [
      {
        "include": "urlRule"
      },
      {
        "pattern": "${any}",
        "style": "comment"
      }
    ],
    "blockComment": [
      {
        "pattern": "\\*\\)",
        "style": "comment",
        "state": "default"
      },
      {
        "include": "urlRule"
      },
      {
        "pattern": "${any}",
        "style": "comment"
      }
    ]
  }
}
