{
  "name": "env",
  "fileSuffixes": [".env"],
  "variables": {
    "whiteSpace": "[ \\t\\f]",
    "any": "[\\S\\s]",
    "ident": "[A-Za-z_][A-Za-z0-9_]*"
  },
  "fragments": {
    "urlRule": [
      {
        "pattern": "(?:(?:https?|ftp)://|www\\.)[A-Za-z0-9._~:/?#\\[\\]@!$&()*+,;=%-]*[A-Za-z0-9_~/#@%=+-]",
        "style": "url"
      }
    ],
    "bracedVariableRule": [
      {
        "pattern": "(\\$\\{)([^}]+)(\\})",
        "styles": [1, "punctuation", 2, "variable", 3, "punctuation"]
      }
    ],
    "simpleVariableRule": [
      {
        "pattern": "(\\$)(${ident})",
        "styles": [1, "punctuation", 2, "variable"]
      }
    ]
  },
  "states": {
    "default": [
      {
        "pattern": "^${whiteSpace}*(#)(.*)$",
        "styles": [1, "comment", 2, "comment"],
        "subStates": [2, "lineCommentContent"]
      },
      {
        "pattern": "^${whiteSpace}*(export)${whiteSpace}+(${ident})${whiteSpace}*(=)(${whiteSpace}*)(true|false|null|yes|no|on|off)(${whiteSpace}*)(#)(.*)$",
        "styles": [1, "keyword", 2, "variable", 3, "punctuation", 5, "builtin", 7, "comment", 8, "comment"],
        "subStates": [8, "lineCommentContent"]
      },
      {
        "pattern": "^${whiteSpace}*(export)${whiteSpace}+(${ident})${whiteSpace}*(=)(${whiteSpace}*)(true|false|null|yes|no|on|off)${whiteSpace}*$",
        "styles": [1, "keyword", 2, "variable", 3, "punctuation", 5, "builtin"]
      },
      {
        "pattern": "^${whiteSpace}*(${ident})${whiteSpace}*(=)(${whiteSpace}*)(true|false|null|yes|no|on|off)(${whiteSpace}*)(#)(.*)$",
        "styles": [1, "variable", 2, "punctuation", 4, "builtin", 6, "comment", 7, "comment"],
        "subStates": [7, "lineCommentContent"]
      },
      {
        "pattern": "^${whiteSpace}*(${ident})${whiteSpace}*(=)(${whiteSpace}*)(true|false|null|yes|no|on|off)${whiteSpace}*$",
        "styles": [1, "variable", 2, "punctuation", 4, "builtin"]
      },
      {
        "pattern": "^${whiteSpace}*(export)${whiteSpace}+(${ident})${whiteSpace}*(=)",
        "styles": [1, "keyword", 2, "variable", 3, "punctuation"],
        "state": "value"
      },
      {
        "pattern": "^${whiteSpace}*(${ident})${whiteSpace}*(=)",
        "styles": [1, "variable", 2, "punctuation"],
        "state": "value"
      }
    ],
    "lineCommentContent": [
      {
        "include": "urlRule"
      },
      {
        "pattern": "${any}",
        "style": "comment"
      }
    ],
    "value": [
      {
        "pattern": "\"",
        "style": "string",
        "state": "doubleStringValue"
      },
      {
        "pattern": "'",
        "style": "string",
        "state": "singleStringValue"
      },
      {
        "pattern": "${whiteSpace}+(#)(.*)$",
        "styles": [1, "comment", 2, "comment"],
        "subStates": [2, "lineCommentContent"],
        "state": "default"
      },
      {
        "includes": ["urlRule", "bracedVariableRule", "simpleVariableRule"]
      },
      {
        "pattern": "(true|false|null|yes|no|on|off)(?=[^A-Za-z0-9_]|$)",
        "style": "builtin"
      },
      {
        "pattern": "[-+]?(?:0[xX][0-9A-Fa-f]+|\\d+\\.\\d+|\\d+)",
        "style": "number"
      },
      {
        "pattern": "[^\\s#]+",
        "style": "string"
      },
      {
        "onLineEndState": "default"
      }
    ],
    "doubleStringValue": [
      {
        "pattern": "\"",
        "style": "string",
        "state": "value"
      },
      {
        "includes": ["urlRule", "bracedVariableRule", "simpleVariableRule"]
      },
      {
        "pattern": "\\\\.",
        "style": "string"
      },
      {
        "pattern": "${any}",
        "style": "string"
      }
    ],
    "singleStringValue": [
      {
        "pattern": "'",
        "style": "string",
        "state": "value"
      },
      {
        "include": "urlRule"
      },
      {
        "pattern": "${any}",
        "style": "string"
      }
    ]
  }
}
