{
  "name": "brainfuck",
  "fileSuffixes": [".bf", ".b"],
  "variables": {
    "any": "[\\S\\s]"
  },
  "states": {
    "default": [
      {
        "pattern": "[^\\-\\+\\.><\\[\\],]+",
        "style": "comment"
      },
      {
        "pattern": "[\\-\\+\\.><,]",
        "style": "keyword"
      },
      {
        "pattern": "\\[",
        "style": "punctuation",
        "state": "loop"
      },
      {
        "pattern": "\\]",
        "style": "punctuation"
      }
    ],
    "loop": [
      {
        "pattern": "[^\\-\\+\\.><\\[\\],\\]]+",
        "style": "comment"
      },
      {
        "pattern": "[\\-\\+\\.><,]",
        "style": "keyword"
      },
      {
        "pattern": "\\[",
        "style": "punctuation",
        "state": "loop"
      },
      {
        "pattern": "\\]",
        "style": "punctuation",
        "state": "default"
      },
      {
        "onLineEndState": "loop"
      }
    ]
  },
  "scopeRules": {
    "skips": [],
    "rules": [
      { "kind": "delimiter", "start": "[", "end": "]" }
    ]
  }
}
